<Window x:Class="AntFarmProject.AntDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Деталі мурахи" 
        Height="400" Width="350"
      Background="{DynamicResource PanelBg}"
        WindowStartupLocation="CenterOwner">

	<Border Style="{StaticResource GamePanel}" Margin="10">
		<StackPanel>
			<TextBlock x:Name="AntNameTitle" Text="Мураха #1" 
                      Style="{StaticResource TitleText}" HorizontalAlignment="Center"/>

			<Border Background="{DynamicResource WinBg}" CornerRadius="8" Padding="15" Margin="0,15">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0" Grid.Column="0" Text="Стан:" Foreground="#b2bec3"/>
					<TextBlock x:Name="StateText" Grid.Row="0" Grid.Column="1" Text="Idle"
                              Foreground="{DynamicResource TextMain}" FontWeight="Bold"/>

					<TextBlock Grid.Row="1" Grid.Column="0" Text="Енергія:" Foreground="#b2bec3"/>
					<ProgressBar x:Name="EnergyBar" Grid.Row="1" Grid.Column="1" 
                                Value="100" Maximum="100" Height="10" 
                                Background="#636e72" Foreground="#00b894"/>

					<TextBlock Grid.Row="2" Grid.Column="0" Text="Здоров'я:" Foreground="#b2bec3"/>
					<ProgressBar x:Name="HealthBar" Grid.Row="2" Grid.Column="1" 
                                Value="100" Maximum="100" Height="10" 
                                Background="#636e72" Foreground="#d63031"/>

					<TextBlock Grid.Row="3" Grid.Column="0" Text="Вік:" Foreground="#b2bec3"/>
					<TextBlock x:Name="AgeText" Grid.Row="3" Grid.Column="1" Text="0 днів"
                              Foreground="{DynamicResource TextMain}"/>
				</Grid>
			</Border>

			<TextBlock Text="📊 Статистика збору:" Style="{StaticResource SubtitleText}" 
                      Margin="0,0,0,10"/>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<TextBlock x:Name="FoodGatheredText" Grid.Row="0" Grid.Column="0" 
                          Text="🍂 0" Foreground="#00b894"/>
				<TextBlock x:Name="WoodGatheredText" Grid.Row="0" Grid.Column="1" 
                          Text="🪵 0" Foreground="#e17055"/>
				<TextBlock x:Name="StoneGatheredText" Grid.Row="1" Grid.Column="0" 
                          Text="🪨 0" Foreground="#b2bec3"/>
				<TextBlock x:Name="WaterGatheredText" Grid.Row="1" Grid.Column="1" 
                          Text="💧 0" Foreground="#0984e3"/>
			</Grid>

			<Button Content="❌ Закрити" Style="{StaticResource GameButton}" 
                   Click="CloseBtn_Click" Margin="0,20,0,0"/>
		</StackPanel>
	</Border>
</Window>