<Window x:Class="AntFarmProject.SaveLoadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Збереження / Завантаження" 
        Height="500" Width="600"
        Background="{DynamicResource PanelBg}"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Text="💾 СЛОТИ ЗБЕРЕЖЕННЯ" 
                  Style="{StaticResource TitleText}" Margin="0,0,0,15"/>

		<ListBox Grid.Row="1" x:Name="SaveList" Background="{DynamicResource WinBg}"
                BorderBrush="{DynamicResource BorderCol}" BorderThickness="2"
		   Foreground="{DynamicResource TextMain}" FontSize="14">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0">
							<TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
							<TextBlock Text="{Binding Date}" Foreground="#b2bec3" FontSize="11"/>
							<TextBlock Text="{Binding Info}" Foreground="#74b9ff" FontSize="10"/>
						</StackPanel>
						<Button Grid.Column="1" Content="🗑" Style="{StaticResource DangerButton}" 
                               Click="DeleteSave_Click" Tag="{Binding FilePath}" 
                               Width="40" Height="40" FontSize="16"/>
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
			<Button x:Name="ActionBtn" Content="💾 Зберегти" Style="{StaticResource SuccessButton}" 
                   Click="ActionBtn_Click" Margin="0,0,10,0"/>
			<Button Content="❌ Скасувати" Style="{StaticResource GameButton}" 
                   Click="CancelBtn_Click"/>
		</StackPanel>
	</Grid>
</Window>