<Window x:Class="AntFarmProject.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика колонії" 
        Height="500" Width="600"
        Background="#2d3436"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Text="📊 ЗАГАЛЬНА СТАТИСТИКА" 
                  Style="{StaticResource TitleText}" Margin="0,0,0,15"/>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<StackPanel>
				<Border Style="{StaticResource GamePanel}">
					<StackPanel>
						<TextBlock Text="💰 Ресурси" Style="{StaticResource SubtitleText}" 
                                  Margin="0,0,0,10"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock x:Name="TotalFoodStat" Grid.Column="0" Text="🍂 Їжа: 0" 
                                      Foreground="#00b894" FontSize="16"/>
							<TextBlock x:Name="TotalWoodStat" Grid.Column="1" Text="🪵 Деревина: 0" 
                                      Foreground="#e17055" FontSize="16"/>
						</Grid>
						<Grid Margin="0,10,0,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock x:Name="TotalStoneStat" Grid.Column="0" Text="🪨 Камінь: 0" 
                                      Foreground="#b2bec3" FontSize="16"/>
							<TextBlock x:Name="TotalWaterStat" Grid.Column="1" Text="💧 Вода: 0" 
                                      Foreground="#0984e3" FontSize="16"/>
						</Grid>
					</StackPanel>
				</Border>

				<Border Style="{StaticResource GamePanel}">
					<StackPanel>
						<TextBlock Text="🐜 Мурахи" Style="{StaticResource SubtitleText}" 
                                  Margin="0,0,0,10"/>
						<TextBlock x:Name="AntsBornStat" Text="🐣 Народилось: 0"/>
						<TextBlock x:Name="AntsDiedStat" Text="💀 Померло: 0" Margin="0,5"/>
						<TextBlock x:Name="AntsAliveStat" Text="❤️ Зараз живі: 0"/>
					</StackPanel>
				</Border>

				<Border Style="{StaticResource GamePanel}">
					<StackPanel>
						<TextBlock Text="🏰 Колонія" Style="{StaticResource SubtitleText}" 
                                  Margin="0,0,0,10"/>
						<TextBlock x:Name="NestLevelStat" Text="Рівень гнізда: 1"/>
						<TextBlock x:Name="ExpansionsStat" Text="Розширень: 0" Margin="0,5"/>
						<TextBlock x:Name="DaysStat" Text="Днів виживання: 1"/>
					</StackPanel>
				</Border>

				<Border Style="{StaticResource GamePanel}">
					<StackPanel>
						<TextBlock Text="⏱️ Час гри" Style="{StaticResource SubtitleText}" 
                                  Margin="0,0,0,10"/>
						<TextBlock x:Name="PlayTimeStat" Text="Загальний час: 00:00:00"/>
					</StackPanel>
				</Border>

				<Button Content="❌ Закрити" Style="{StaticResource GameButton}" 
                       Click="CloseBtn_Click" Margin="0,10,0,0"/>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Window>